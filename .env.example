# MTG MCP Server Configuration
# Copy to .env and adjust as needed. All values shown are defaults.

# --- Publishing ---
# CI uses trusted publishing (OIDC) via .github/workflows/publish.yml — no token needed.
# For manual local publishing only:
# UV_PUBLISH_TOKEN=pypi-...

# --- Transport ---
MTG_MCP_TRANSPORT=stdio              # stdio | http
MTG_MCP_HTTP_PORT=8000

# --- Logging ---
MTG_MCP_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# --- Scryfall (public, no auth) ---
MTG_MCP_SCRYFALL_BASE_URL=https://api.scryfall.com
MTG_MCP_SCRYFALL_RATE_LIMIT_MS=100

# --- Commander Spellbook (public, no auth) ---
MTG_MCP_SPELLBOOK_BASE_URL=https://backend.commanderspellbook.com

# --- 17Lands (public, no auth — aggressive rate limits) ---
MTG_MCP_SEVENTEEN_LANDS_BASE_URL=https://www.17lands.com
MTG_MCP_ENABLE_17LANDS=true

# --- EDHREC (undocumented endpoints, no auth — will break) ---
MTG_MCP_EDHREC_BASE_URL=https://json.edhrec.com
MTG_MCP_ENABLE_EDHREC=true

# --- Caching ---
MTG_MCP_DISABLE_CACHE=false          # Set true to bypass all TTL caches (debugging)

# --- MTGJSON (bulk card data, no auth) ---
MTG_MCP_MTGJSON_DATA_URL=https://mtgjson.com/api/v5/AtomicCards.json.gz
MTG_MCP_MTGJSON_REFRESH_HOURS=24
MTG_MCP_ENABLE_MTGJSON=true
